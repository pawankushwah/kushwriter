{
  "name": "kushwriter",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "cross-env IS_ELECTRON=true concurrently -k \"npm run dev\" \"wait-on tcp:5173 && npx electron .\"",
    "electron:build": "cross-env IS_ELECTRON=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder",
    "electron:publish": "cross-env IS_ELECTRON=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.kushwriter.app",
    "productName": "KushWriter",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pawankushwah",
        "repo": "kushwriter"
      }
    ],
    "mac": {
      "icon": "build/icon.icns"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.15",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
